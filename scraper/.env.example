# .env.example
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is in .gitignore — it will NEVER be committed to GitHub.
#
# HOW TO USE:
#   1. Copy:  cp .env.example .env   (Mac/Linux)
#             copy .env.example .env  (Windows)
#   2. Paste your token and cookie into .env
#   3. The scripts will read from .env automatically
# ─────────────────────────────────────────────────────────────────

MB_TOKEN=Bearer PASTE_YOUR_TOKEN_HERE
MB_COOKIE=PASTE_YOUR_FULL_COOKIE_HERE